{
  "manifest_version": 3,
  "name": "YWH Program Description Extractor",
  "version": "1.0.0",
  "description": "Extract program descriptions from YesWeHack program pages and export as JSON, TXT, or MD.",
  "permissions": ["activeTab"],
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://yeswehack.com/programs/*"],
      "js": ["content.js"]
    }
  ]
}
